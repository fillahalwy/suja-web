{
  "name": "suja-web",
  "version": "1.0.0",
  "description": "Landing page profesional untuk Suja Web - Solusi Digital Terintegrasi",
  "main": "index.html",
  "scripts": {
    "dev": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css --watch",
    "build": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css --minify && node scripts/build.js",
    "preview": "npx http-server public"
  },
  "keywords": [
    "tailwind",
    "landing-page",
    "web-development",
    "suja-web"
  ],
  "author": "Suja Web Team",
  "license": "MIT",
  "devDependencies": {
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16"
  }
}
